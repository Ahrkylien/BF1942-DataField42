<Application x:Class="DataField42.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DataField42"
             xmlns:converters="clr-namespace:DataField42.Converters"
             xmlns:controls="clr-namespace:DataField42.Controls"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <Style TargetType="{x:Type controls:SimpleButton}">
            <Setter Property="Background" Value="#1b1e2a"/>
            <Setter Property="BorderBrush" Value="#233050"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#233050"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
