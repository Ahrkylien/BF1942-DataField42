<UserControl x:Class="DataField42.Views.ServerInfo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ViewModels="clr-namespace:DataField42.ViewModels"
             xmlns:Controls="clr-namespace:DataField42.Controls"
             xmlns:Converters="clr-namespace:DataField42.Converters"
             xmlns:svg="https://github.com/dotnetprojects/SVGImage"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance ViewModels:ServerViewModel, IsDesignTimeCreatable=False}">
    <UserControl.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4a5680"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#c0ccdd"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Name + IP + Join button -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding Name}" Foreground="#e0e8ff" FontWeight="Bold" FontSize="16"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding IpAndGamePort}" Foreground="#4a5680" FontSize="10" Margin="0,2,0,0"/>
            </StackPanel>
            <Controls:SimpleButton Grid.Column="1" Width="32" Height="32" VerticalAlignment="Center" Command="{Binding JoinServerCommand}">
                <svg:SVGImage UriSource="/Resources/Images/play.svg"
                              SizeType="ViewBoxToSizeNoStretch"
                              OverrideStrokeColor="#d4d4d4"
                              Margin="8"/>
            </Controls:SimpleButton>
        </Grid>

        <!-- Row 1: Players bar + time bar -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="PLAYERS" FontSize="9" Foreground="#4a5680" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ProgressBar Grid.Column="1" Value="{Binding NumberOfPlayers, Mode=OneWay}"
                             Maximum="{Binding MaximumNumberOfPlayers, Mode=OneWay}"
                             Height="4" Background="#1a2040" Foreground="#60a8ff"
                             BorderThickness="0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                    <TextBlock Text="{Binding Players}" Foreground="#8899bb" FontWeight="Bold" FontSize="11"/>
                    <TextBlock Text=" 🔒" Foreground="#e06c75" FontSize="10" VerticalAlignment="Center"
                               Visibility="{Binding HasPassword, Converter={Converters:BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1"
                  Visibility="{Binding RoundTimeTotalDisplay, Converter={Converters:StringNotEmptyToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="TIME" FontSize="9" Foreground="#4a5680" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1" Text="{Binding RoundTimeElapsedDisplay}"
                           Foreground="#4a5680" FontSize="9" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ProgressBar Grid.Column="2" Value="{Binding RoundTimeRemain, Mode=OneWay}"
                             Maximum="{Binding RoundTime, Mode=OneWay}"
                             Height="4" Background="#1a2040" Foreground="#e0a040"
                             FlowDirection="RightToLeft"
                             BorderThickness="0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="{Binding RoundTimeRemainDisplay}"
                           Foreground="#e0a040" FontSize="9" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Grid>

        <!-- Row 2: Map name (prominent) + game mode -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="{Binding Map}" FontSize="18" FontWeight="Bold" Foreground="#c8d8f0"
                TextTrimming="CharacterEllipsis"/>
            <Border Background="#111830" CornerRadius="4" Padding="8,4" Margin="2,0,0,0"
                Visibility="{Binding Mode, Converter={Converters:StringNotEmptyToVisibilityConverter}}">
                <TextBlock Text="{Binding Mode}" FontSize="11" Foreground="#aabbd0" FontWeight="Bold" VerticalAlignment="Center"/>
            </Border>
            <Border Background="#111830" CornerRadius="4" Padding="8,4" Margin="2,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="MOD" FontSize="9" Foreground="#4a5680" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Mod}" FontSize="11" Foreground="#aabbd0" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Background="#1a1020" CornerRadius="4" Padding="8,4" Margin="2,0,0,0"
                Visibility="{Binding HasPassword, Converter={Converters:BooleanToVisibilityConverter}}">
                <TextBlock Text="🔒 PW" FontSize="9" Foreground="#e06c75" FontWeight="Bold" VerticalAlignment="Center"/>
            </Border>
            <Border Background="#0f1a10" CornerRadius="4" Padding="8,4" Margin="2,0,0,0"
                Visibility="{Binding HasPunkbuster, Converter={Converters:BooleanToVisibilityConverter}}">
                <TextBlock Text="PunkBuster" FontSize="9" Foreground="#84db81" FontWeight="Bold" VerticalAlignment="Center"/>
            </Border>
            <Border Background="#111830" CornerRadius="4" Padding="8,4" Margin="2,0,0,0"
                Visibility="{Binding GameVersion, Converter={Converters:StringNotEmptyToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="VER" FontSize="9" Foreground="#4a5680" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding GameVersion}" FontSize="11" Foreground="#aabbd0" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Row 4: Team panels (Team 1 = red, Team 2 = blue) -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Team 1 (red) -->
            <Border Grid.Column="0" Background="#090b18" CornerRadius="6" BorderBrush="#1a2540" BorderThickness="1">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#180f10" CornerRadius="6,6,0,0" Padding="10,7">
                        <Grid>
                            <TextBlock Text="{Binding Team1Name}" FontWeight="Bold" Foreground="#e07060" FontSize="12"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="10" Foreground="#4a5680"
                                       Visibility="{Binding Team1Score, Converter={Converters:StringNotEmptyToVisibilityConverter}}">
                                <Run Text="{Binding Team1Score, Mode=OneWay}"/><Run Text=" tickets"/>
                            </TextBlock>
                        </Grid>
                    </Border>
                    <Grid DockPanel.Dock="Top" Margin="10,5,10,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition Width="26"/>
                            <ColumnDefinition Width="26"/>
                            <ColumnDefinition Width="34"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="PLAYER" FontSize="9" Foreground="#4a5680" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="SCR" FontSize="9" Foreground="#4a5680" TextAlignment="Right"/>
                        <TextBlock Grid.Column="2" Text="K" FontSize="9" Foreground="#84db81" FontWeight="Bold" TextAlignment="Right"/>
                        <TextBlock Grid.Column="3" Text="D" FontSize="9" Foreground="#e06c75" FontWeight="Bold" TextAlignment="Right"/>
                        <TextBlock Grid.Column="4" Text="PING" FontSize="9" Foreground="#4a5680" TextAlignment="Right"/>
                    </Grid>
                    <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding AllTeam1Players}" Margin="0,0,0,6">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="10,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#ccd4e0" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Score}" Foreground="#ccd4e0" FontSize="11" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Kills}" Foreground="#84db81" FontSize="11" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Deaths}" Foreground="#e06c75" FontSize="11" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="{Binding Ping}" Foreground="#8899bb" FontSize="11" TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- Team 2 (blue) -->
            <Border Grid.Column="2" Background="#090b18" CornerRadius="6" BorderBrush="#1a2540" BorderThickness="1">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#0f1530" CornerRadius="6,6,0,0" Padding="10,7">
                        <Grid>
                            <TextBlock Text="{Binding Team2Name}" FontWeight="Bold" Foreground="#60a8ff" FontSize="12"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="10" Foreground="#4a5680"
                                       Visibility="{Binding Team2Score, Converter={Converters:StringNotEmptyToVisibilityConverter}}">
                                <Run Text="{Binding Team2Score, Mode=OneWay}"/><Run Text=" tickets"/>
                            </TextBlock>
                        </Grid>
                    </Border>
                    <Grid DockPanel.Dock="Top" Margin="10,5,10,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition Width="26"/>
                            <ColumnDefinition Width="26"/>
                            <ColumnDefinition Width="34"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="PLAYER" FontSize="9" Foreground="#4a5680" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="SCR" FontSize="9" Foreground="#4a5680" TextAlignment="Right"/>
                        <TextBlock Grid.Column="2" Text="K" FontSize="9" Foreground="#84db81" FontWeight="Bold" TextAlignment="Right"/>
                        <TextBlock Grid.Column="3" Text="D" FontSize="9" Foreground="#e06c75" FontWeight="Bold" TextAlignment="Right"/>
                        <TextBlock Grid.Column="4" Text="PING" FontSize="9" Foreground="#4a5680" TextAlignment="Right"/>
                    </Grid>
                    <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding AllTeam2Players}" Margin="0,0,0,6">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="10,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#ccd4e0" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Score}" Foreground="#ccd4e0" FontSize="11" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Kills}" Foreground="#84db81" FontSize="11" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Deaths}" Foreground="#e06c75" FontSize="11" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="{Binding Ping}" Foreground="#8899bb" FontSize="11" TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Row 5: Settings panel (4 blocks: ROUND + GAME RULES left, SERVER INFO + FRIENDLY FIRE right) -->
        <Grid Grid.Row="4" Visibility="{Binding HasQueryResult, Converter={Converters:BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left column: ROUND + GAME RULES -->
            <StackPanel Grid.Column="0">

                <!-- GAME RULES block -->
                <Border Background="#090b18" CornerRadius="6" BorderBrush="#1a2540" BorderThickness="1" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="GAME RULES" FontSize="9" Foreground="#4a5680" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Auto Balance Teams"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2" Text="{Binding AutoBalanceTeams}"/>
                        <TextBlock Grid.Row="2" Style="{StaticResource LabelStyle}" Margin="0,2" Text="External View"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2" Text="{Binding ExternalView}"/>
                        <TextBlock Grid.Row="3" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Allow Nose Cam"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2" Text="{Binding AllowNoseCam}"/>
                        <TextBlock Grid.Row="4" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Free Camera"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2" Text="{Binding FreeCamera}"/>
                        <TextBlock Grid.Row="5" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Hit Indicator"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2" Text="{Binding HitIndicator}"/>
                        <TextBlock Grid.Row="6" Style="{StaticResource LabelStyle}" Margin="0,2" Text="PunkBuster"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2" Text="{Binding HasPunkbuster}"/>
                        <TextBlock Grid.Row="7" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Password"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2" Text="{Binding HasPassword}"/>
                        <TextBlock Grid.Row="8" Style="{StaticResource LabelStyle}" Margin="0,2"
                                   Visibility="{Binding NameTagDistance, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="Name Tag Distance"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"
                                   Visibility="{Binding NameTagDistance, Converter={Converters:StringNotEmptyToVisibilityConverter}}"><Run Text="{Binding NameTagDistance, Mode=OneWay}"/><Run Text="m" Foreground="#4a5680"/></TextBlock>
                        <TextBlock Grid.Row="9" Style="{StaticResource LabelStyle}" Margin="0,2"
                                   Visibility="{Binding NameTagDistanceScope, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="Name Tag Distance Scope"/>
                        <TextBlock Grid.Row="9" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"
                                   Visibility="{Binding NameTagDistanceScope, Converter={Converters:StringNotEmptyToVisibilityConverter}}"><Run Text="{Binding NameTagDistanceScope, Mode=OneWay}"/><Run Text="m" Foreground="#4a5680"/></TextBlock>
                        <TextBlock Grid.Row="10" Style="{StaticResource LabelStyle}" Margin="0,2"
                                   Visibility="{Binding NumberOfRounds, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="Number of Rounds"/>
                        <TextBlock Grid.Row="10" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"
                                   Visibility="{Binding NumberOfRounds, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="{Binding NumberOfRounds}"/>
                        <TextBlock Grid.Row="11" Style="{StaticResource LabelStyle}" Margin="0,2"
                                   Visibility="{Binding ReservedSlots, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="Reserved Slots"/>
                        <TextBlock Grid.Row="11" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"
                                   Visibility="{Binding ReservedSlots, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="{Binding ReservedSlots}"/>
                        <TextBlock Grid.Row="12" Style="{StaticResource LabelStyle}" Margin="0,2"
                                   Visibility="{Binding TicketRatio, Converter={Converters:NullableToVisibilityConverter}}" Text="Ticket Ratio"/>
                        <TextBlock Grid.Row="12" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"
                                   Visibility="{Binding TicketRatio, Converter={Converters:NullableToVisibilityConverter}}"><Run Text="{Binding TicketRatio, Mode=OneWay}"/><Run Text="%" Foreground="#4a5680"/></TextBlock>
                        <TextBlock Grid.Row="14" Style="{StaticResource LabelStyle}" Margin="0,2"
                                   Visibility="{Binding TeamRatio, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="Team Ratio (Axis:Allied)"/>
                        <TextBlock Grid.Row="14" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"
                                   Visibility="{Binding TeamRatio, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="{Binding TeamRatio}"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Right column: SERVER INFO + FRIENDLY FIRE & GAMEPLAY -->
            <StackPanel Grid.Column="2">

                <!-- ROUND & SERVER INFO block -->
                <Border Background="#090b18" CornerRadius="6" BorderBrush="#1a2540" BorderThickness="1" Padding="12,8" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="ROUND &amp; SERVER INFO" FontSize="9" Foreground="#4a5680" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Style="{StaticResource LabelStyle}" Margin="0,2"
                                   Visibility="{Binding Stage, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="Stage"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"
                                   Visibility="{Binding Stage, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="{Binding Stage}"/>
                        <TextBlock Grid.Row="2" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Status"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2" Text="{Binding Status}"/>
                        <TextBlock Grid.Row="3" Style="{StaticResource LabelStyle}" Margin="0,2"
                                   Visibility="{Binding ActiveMods, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="Active Mods"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"
                                   Visibility="{Binding ActiveMods, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="{Binding ActiveMods}"/>
                        <TextBlock Grid.Row="4" Style="{StaticResource LabelStyle}" Margin="0,2"
                                   Visibility="{Binding DedicatedServerType, Converter={Converters:NullableToVisibilityConverter}}" Text="Host Type"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"
                                   Visibility="{Binding DedicatedServerType, Converter={Converters:NullableToVisibilityConverter}}"
                                   Text="{Binding DedicatedServerType, Converter={Converters:EnumDescriptionConverter}}"/>
                        <TextBlock Grid.Row="5" Style="{StaticResource LabelStyle}" Margin="0,2"
                                   Visibility="{Binding Cpu, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="CPU"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"
                                   Visibility="{Binding Cpu, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="{Binding Cpu}"/>
                        <TextBlock Grid.Row="6" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Average FPS"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"><Run Text="{Binding AverageFps, Mode=OneWay}"/><Run Text=" fps" Foreground="#4a5680"/></TextBlock>
                        <TextBlock Grid.Row="7" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Bandwidth Choke"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"><Run Text="{Binding BandwidthChokeLimit, Mode=OneWay}"/><Run Text=" kbps" Foreground="#4a5680"/></TextBlock>
                        <TextBlock Grid.Row="8" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Content Check"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2" Text="{Binding ContentCheck}"/>
                        <TextBlock Grid.Row="9" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Mods w/o Content Check"/>
                        <TextBlock Grid.Row="9" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2" Text="{Binding UnpureModsDisplay}"/>
                        <TextBlock Grid.Row="10" Style="{StaticResource LabelStyle}" Margin="0,2"
                                   Visibility="{Binding Language, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="Language"/>
                        <TextBlock Grid.Row="10" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"
                                   Visibility="{Binding Language, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="{Binding Language}"/>
                        <TextBlock Grid.Row="11" Style="{StaticResource LabelStyle}" Margin="0,2"
                                   Visibility="{Binding Location, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="Location"/>
                        <TextBlock Grid.Row="11" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"
                                   Visibility="{Binding Location, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="{Binding Location}"/>
                    </Grid>
                </Border>

                <!-- FRIENDLY FIRE & GAMEPLAY block -->
                <Border Background="#090b18" CornerRadius="6" BorderBrush="#1a2540" BorderThickness="1" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="FRIENDLY FIRE &amp; GAMEPLAY" FontSize="9" Foreground="#4a5680" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Style="{StaticResource LabelStyle}" Margin="0,2"
                                   Visibility="{Binding TkMode, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="Team Kill Mode"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"
                                   Visibility="{Binding TkMode, Converter={Converters:StringNotEmptyToVisibilityConverter}}" Text="{Binding TkMode}"/>
                        <TextBlock Grid.Row="2" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Spawn Delay"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"><Run Text="{Binding SpawnDelay, Mode=OneWay}"/><Run Text="s" Foreground="#4a5680"/></TextBlock>
                        <TextBlock Grid.Row="3" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Spawn Wave Time"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"><Run Text="{Binding SpawnWaveTime, Mode=OneWay}"/><Run Text="s" Foreground="#4a5680"/></TextBlock>
                        <TextBlock Grid.Row="4" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Game Start Delay"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"><Run Text="{Binding GameStartDelay, Mode=OneWay}"/><Run Text="s" Foreground="#4a5680"/></TextBlock>
                        <TextBlock Grid.Row="5" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Soldier FF"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"><Run Text="{Binding SoldierFriendlyFire, Mode=OneWay}"/><Run Text="%" Foreground="#4a5680"/></TextBlock>
                        <TextBlock Grid.Row="6" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Soldier FF Splash"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"><Run Text="{Binding SoldierFriendlyFireOnSplash, Mode=OneWay}"/><Run Text="%" Foreground="#4a5680"/></TextBlock>
                        <TextBlock Grid.Row="7" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Vehicle FF"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"><Run Text="{Binding VehicleFriendlyFire, Mode=OneWay}"/><Run Text="%" Foreground="#4a5680"/></TextBlock>
                        <TextBlock Grid.Row="8" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Vehicle FF Splash"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"><Run Text="{Binding VehicleFriendlyFireOnSplash, Mode=OneWay}"/><Run Text="%" Foreground="#4a5680"/></TextBlock>
                        <TextBlock Grid.Row="9" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Kickback"/>
                        <TextBlock Grid.Row="9" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"><Run Text="{Binding KickBack, Mode=OneWay}"/><Run Text="%" Foreground="#4a5680"/></TextBlock>
                        <TextBlock Grid.Row="10" Style="{StaticResource LabelStyle}" Margin="0,2" Text="Kickback on Splash"/>
                        <TextBlock Grid.Row="10" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,2"><Run Text="{Binding KickBackOnSplash, Mode=OneWay}"/><Run Text="%" Foreground="#4a5680"/></TextBlock>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
