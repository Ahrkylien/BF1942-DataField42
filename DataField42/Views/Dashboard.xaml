<UserControl x:Class="DataField42.Views.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ViewModels="clr-namespace:DataField42.ViewModels"
             xmlns:Controls="clr-namespace:DataField42.Controls"
             xmlns:Converters="clr-namespace:DataField42.Converters"
             xmlns:Views="clr-namespace:DataField42.Views"
             xmlns:svg="https://github.com/dotnetprojects/SVGImage"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance ViewModels:DashboardViewModel, IsDesignTimeCreatable=True}">
    <UserControl.Resources>
        <DrawingBrush x:Key="DashedBorderBrush" Viewport="0,0,8,8" ViewportUnits="Absolute" TileMode="Tile">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#233050">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,50,50"/>
                                <RectangleGeometry Rect="50,50,50,50"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- 4-card card content template -->
        <DataTemplate x:Key="CardContent">
            <Grid Margin="8,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>   <!-- name -->
                    <RowDefinition Height="auto"/>   <!-- players + time bars -->
                    <RowDefinition Height="auto"/>   <!-- map/mod/mode -->
                    <RowDefinition Height="auto"/>   <!-- teams -->
                </Grid.RowDefinitions>

                <!-- Row 0: Server name (full width — leave top-right clear for edit btn) -->
                <TextBlock Grid.Row="0" Text="{Binding Name}" Foreground="#e0e8ff" FontWeight="Bold"
                           FontSize="13" TextTrimming="CharacterEllipsis" Margin="0,0,0,5"/>

                <!-- Row 1: Players bar + time remaining bar -->
                <TextBlock Grid.Row="1" Margin="0,0,0,5"
                           Visibility="{Binding ConnectionState.Value, Converter={Converters:EnumToVisibilityConverter}, ConverterParameter=Connecting}"
                           Text="Connecting..." Foreground="#3a4560" FontSize="11"/>
                <TextBlock Grid.Row="1" Margin="0,0,0,5"
                           Visibility="{Binding ConnectionState.Value, Converter={Converters:EnumToVisibilityConverter}, ConverterParameter=Disconnected}"
                           Text="Offline" Foreground="#7a3333" FontSize="11" FontWeight="Bold"/>
                <Grid Grid.Row="1" Margin="0,0,0,5"
                      Visibility="{Binding ConnectionState.Value, Converter={Converters:EnumToVisibilityConverter}, ConverterParameter=Connected}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <!-- Players -->
                    <Grid Grid.Row="0" Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="PLAYERS" FontSize="9" Foreground="#4a5680"
                                   FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ProgressBar Grid.Column="1" Value="{Binding NumberOfPlayers, Mode=OneWay}"
                                     Maximum="{Binding MaximumNumberOfPlayers}"
                                     Height="4" Background="#1a2040" Foreground="#60a8ff"
                                     BorderThickness="0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="6,0,0,0">
                            <TextBlock Text="{Binding Players}" Foreground="#60a8ff" FontWeight="Bold" FontSize="11"/>
                            <TextBlock Text=" 🔒" Foreground="#e06c75" FontSize="10" VerticalAlignment="Center"
                                       Visibility="{Binding HasPassword, Converter={Converters:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Time remaining (only when available) -->
                    <Grid Grid.Row="1"
                          Visibility="{Binding RoundTimeRemainDisplay, Converter={Converters:StringNotEmptyToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TIME  " FontSize="9" Foreground="#4a5680"
                                   FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ProgressBar Grid.Column="1" Value="{Binding RoundTimeRemain, Mode=OneWay}"
                                     Maximum="{Binding RoundTime, Mode=OneWay}"
                                     Height="4" Background="#1a2040" Foreground="#e0a040"
                                     FlowDirection="RightToLeft"
                                     BorderThickness="0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding RoundTimeRemainDisplay}"
                                   Foreground="#e0a040" FontSize="9" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>

                <!-- Row 2: Map · Mod · Mode -->
                <WrapPanel Grid.Row="2" Margin="0,0,0,6"
                           Visibility="{Binding ConnectionState.Value, Converter={Converters:EnumToVisibilityConverter}, ConverterParameter=Connected}">
                    <TextBlock Text="{Binding Map, Converter={Converters:TitleCaseConverter}}" Foreground="#7788aa" FontSize="14"/>
                    <TextBlock Text=" · " Foreground="#3a4560" FontSize="14"/>
                    <TextBlock Text="{Binding Mod, Converter={Converters:TitleCaseConverter}}" Foreground="#7788aa" FontSize="14"/>
                    <TextBlock Text=" · " Foreground="#3a4560" FontSize="14"
                               Visibility="{Binding Mode, Converter={Converters:StringNotEmptyToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding Mode}" Foreground="#7788aa" FontSize="14"
                               Visibility="{Binding Mode, Converter={Converters:StringNotEmptyToVisibilityConverter}}"/>
                </WrapPanel>

                <!-- Row 3: Top-3 team columns -->
                <Grid Grid.Row="3"
                      Visibility="{Binding ConnectionState.Value, Converter={Converters:EnumToVisibilityConverter}, ConverterParameter=Connected}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,2">
                            <TextBlock Text="{Binding Team1Name}" Foreground="#e07060" FontSize="9" FontWeight="Bold"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="9" Foreground="#4a5680"
                                       Visibility="{Binding Team1Score, Converter={Converters:StringNotEmptyToVisibilityConverter}}">
                                <Run Text="{Binding Team1Score, Mode=OneWay}"/><Run Text=" tkts"/>
                            </TextBlock>
                        </Grid>
                        <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Team1Players}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="26"/>
                                            <ColumnDefinition Width="20"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#c0ccdd" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Score}" Foreground="#8899bb" FontSize="10" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Kills}" Foreground="#5a8a58" FontSize="10" TextAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>

                    <Border Grid.Column="1" Background="#1a2540" Margin="10,0" Width="1"/>

                    <DockPanel Grid.Column="2">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,2">
                            <TextBlock Text="{Binding Team2Name}" Foreground="#60a8ff" FontSize="9" FontWeight="Bold"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="9" Foreground="#4a5680"
                                       Visibility="{Binding Team2Score, Converter={Converters:StringNotEmptyToVisibilityConverter}}">
                                <Run Text="{Binding Team2Score, Mode=OneWay}"/><Run Text=" tkts"/>
                            </TextBlock>
                        </Grid>
                        <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Team2Players}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="26"/>
                                            <ColumnDefinition Width="20"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#c0ccdd" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Score}" Foreground="#8899bb" FontSize="10" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Kills}" Foreground="#5a8a58" FontSize="10" TextAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Grid>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <!-- ── 2×2 multi-card mode ─────────────────────────────────────────── -->
        <ItemsControl ItemsSource="{Binding FavoriteServers}"
                      Visibility="{Binding DataContext.DisplayOneServer, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Converter={Converters:InverseBooleanToVisibilityConverter}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="6">
                        <!-- Edit overlay -->
                        <Border Visibility="{Binding DataContext.EditModeEnabled, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Converter={Converters:BooleanToVisibilityConverter}}"
                                BorderThickness="2" CornerRadius="8" BorderBrush="{StaticResource DashedBorderBrush}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style>
                                    <Setter Property="Border.Background" Value="#1b1e2a"/>
                                    <Style.Triggers>
                                        <Trigger Property="Border.IsMouseOver" Value="True">
                                            <Setter Property="Border.Background" Value="#233050"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Label HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#d4d4d4"
                                       Padding="0" FontSize="20" Content="Add"
                                       Visibility="{Binding GeneratedItem, Converter={Converters:BooleanToVisibilityConverter}}"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Visibility="{Binding GeneratedItem, Converter={Converters:InverseBooleanToVisibilityConverter}}">
                                    <Label Foreground="#d4d4d4" Padding="0" HorizontalContentAlignment="Center" FontWeight="Bold" FontSize="12" Content="{Binding Name}"/>
                                    <Label Foreground="#d4d4d4" Padding="0" HorizontalContentAlignment="Center" FontSize="20" Content="Change"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- View mode -->
                        <Controls:SimpleButton
                            Visibility="{Binding DataContext.EditModeEnabled, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Converter={Converters:InverseBooleanToVisibilityConverter}}"
                            BorderThickness="0" Command="{Binding ClickCommand}">
                            <ContentControl Content="{Binding}" ContentTemplate="{StaticResource CardContent}"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                        </Controls:SimpleButton>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ── Single-server mode ─────────────────────────────────────────── -->
        <Grid Visibility="{Binding DataContext.DisplayOneServer, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Converter={Converters:BooleanToVisibilityConverter}}">
            <!-- Edit overlay -->
            <Border DataContext="{Binding FirstFavoriteServers}"
                    Visibility="{Binding DataContext.EditModeEnabled, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Converter={Converters:BooleanToVisibilityConverter}}"
                    Margin="6" BorderThickness="2" CornerRadius="8" BorderBrush="{StaticResource DashedBorderBrush}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                        Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                        CommandParameter="{Binding}"/>
                </Border.InputBindings>
                <Border.Style>
                    <Style>
                        <Setter Property="Border.Background" Value="#1b1e2a"/>
                        <Style.Triggers>
                            <Trigger Property="Border.IsMouseOver" Value="True">
                                <Setter Property="Border.Background" Value="#233050"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Label HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#d4d4d4"
                           Padding="0" FontSize="20" Content="Add"
                           Visibility="{Binding GeneratedItem, Converter={Converters:BooleanToVisibilityConverter}}"/>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding GeneratedItem, Converter={Converters:InverseBooleanToVisibilityConverter}}">
                        <Label Foreground="#d4d4d4" Padding="0" HorizontalContentAlignment="Center" FontWeight="Bold" FontSize="12" Content="{Binding Name}"/>
                        <Label Foreground="#d4d4d4" Padding="0" HorizontalContentAlignment="Center" FontSize="20" Content="Change"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- View mode: full server info inline -->
            <Views:ServerInfo
                Visibility="{Binding DataContext.EditModeEnabled, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Converter={Converters:InverseBooleanToVisibilityConverter}}"
                Margin="6"
                DataContext="{Binding FirstFavoriteServers}"/>
        </Grid>

        <!-- Edit/save toggle (top-right, always on top) -->
        <Controls:SimpleButton VerticalAlignment="Top" HorizontalAlignment="Right"
                               Height="40" Width="40"
                               Command="{Binding ToggleEditModeCommand}">
            <Controls:SimpleButton.Style> <!-- dirty fix for avoiding overlapping buttons -->
                <Style TargetType="Controls:SimpleButton" BasedOn="{StaticResource {x:Type Controls:SimpleButton}}">
                    <Setter Property="Margin" Value="-5"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding DisplayOneServer}" Value="True"/>
                                <Condition Binding="{Binding EditModeEnabled}" Value="False"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Margin" Value="55,5"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Controls:SimpleButton.Style>
            <Grid>
                <svg:SVGImage Visibility="{Binding EditModeEnabled, Converter={Converters:InverseBooleanToVisibilityConverter}}"
                              UriSource="/Resources/Images/edit.svg" SizeType="ViewBoxToSizeNoStretch"
                              OverrideStrokeColor="#60a8ff" Margin="5"/>
                <svg:SVGImage Visibility="{Binding EditModeEnabled, Converter={Converters:BooleanToVisibilityConverter}}"
                              UriSource="/Resources/Images/check.svg" SizeType="ViewBoxToSizeNoStretch"
                              OverrideStrokeColor="#84db81" Margin="5"/>
            </Grid>
        </Controls:SimpleButton>
    </Grid>
</UserControl>
