<UserControl x:Class="DataField42.Views.Settings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DataField42.Views"
             xmlns:Converters="clr-namespace:DataField42.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid VerticalAlignment="Top">
        <StackPanel Orientation="Horizontal" Height="22">
            <TextBlock
                Text="Dashboard Mode"
                Margin="0,0,10,0"
                Foreground="#d4d4d4"
                VerticalAlignment="Center"/>
            <ComboBox
                ItemsSource="{Binding DashboardModes}"
                SelectedItem="{Binding SelectedDashboardMode, Mode=TwoWay}"
                Width="200"/>
        </StackPanel>
    </Grid>
</UserControl>
